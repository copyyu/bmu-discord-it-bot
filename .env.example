# PostgreSQL connection string (Railway: Database → Connect → Public Network)
# รูปแบบ: postgresql://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Discord webhook สำหรับ IT Tickets (จำเป็น)
# Channel Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_IT_TICKET=https://discord.com/api/webhooks/.../...

# Discord webhook สำหรับ Equipment Borrowings (ไม่บังคับ — เว้นว่างเพื่อปิด feature นี้)
# สร้าง webhook ใน channel คนละช่องจาก IT tickets
DISCORD_WEBHOOK_EQUIPMENT=

# Discord webhook สำหรับ Check-in/out (ไม่บังคับ — เว้นว่างเพื่อปิด feature นี้)
# สร้าง webhook ใน channel แยกอีกช่อง
DISCORD_WEBHOOK_CHECKIN=

# รายชื่อ username ที่จะแจ้งเตือนตอนเช็คอิน/เอาท์ (คั่นด้วย comma) — ว่าง = ไม่แจ้งใครเลย
# เปลี่ยนรายชื่อที่นี่ได้เลย ไม่ต้องรัน SQL ใหม่
CHECKIN_USERNAMES=Siraphob.pat,Chayapol.jit,mossit,Yuttana.wis,Taechit.suw,kenshiro

# Optional: mention ตอน check-in (default '' = ไม่ ping — กัน spam เพราะวันละหลายสิบครั้ง)
# CHECKIN_MENTION=

# Optional: override displayed bot name (default "BMU IT Bot")
# BOT_NAME=BMU IT Bot

# Optional: mention ที่จะใช้ (default '@everyone'; '@here' / '<@&ROLE_ID>' / '' เพื่อปิด)
# MENTION=@everyone

# Optional: ms to wait before reconnect on DB drop (default 5000)
# RECONNECT_DELAY_MS=5000
